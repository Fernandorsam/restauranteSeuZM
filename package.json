{
  "name": "seu-ze-seu-mane-api",
  "version": "1.0.0",
  "description": "API do Restaurante Seu Zé e Seu Mané",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "debug": "nodemon --inspect server.js",
    "test:watch": "jest --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs",
    "test:ci": "jest --coverage --config ./jest.config.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/**/*.js",
    "docs": "jsdoc -c jsdoc.json",
    "seed": "node src/seeds/index.js",
    "backup": "node src/scripts/backup.js",
    "analyze-logs": "node src/scripts/analyzeLogs.js",
    "rotate-logs": "node src/utils/logRotation.js",
    "clean-logs": "node -e \"require('./src/utils/logRotation').cleanupOldLogs()\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "redis": "^5.12.1",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "eslint": "^10.3.0",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.5",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "sinon": "^22.0.0",
    "supertest": "^7.2.2"
  }
}
